# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
# In production (GitHub Actions), these are set as GitHub Secrets.

# Google Sheets via Apps Script
APPSSCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
APPSSCRIPT_SECRET=your_random_secret_key_here

# Slack (optional — remove this line if you don't want Slack alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Snowflake PAT (optional — only if IT enables Programmatic Access)
SNOWFLAKE_PAT=

# For test_connection.py — a sheet URL to do a write test
TEST_SHEET_URL=
